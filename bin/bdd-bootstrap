#!/usr/bin/env python3
"""Install the Gherkin BDD skill into the current directory for Claude Code or Codex.

Usage:

    bdd-bootstrap claude    # install for Claude Code + register its hook
    bdd-bootstrap codex     # install for Codex + register its hook

What gets installed: the gherkin-bdd skill (SKILL.md, the BDD rule BDD.md, and
the skill's scripts — the BDD-rule sync and the gherkin-to-html converter), the
companion skills (bdd-bootstrap, code-to-gherkin; one SKILL.md each), and a
SessionStart hook — nothing else. The skill goes into the coding agent's
project-level skills directory (.claude/skills/ or .agents/skills/), which both
coding agents discover natively; there is no plugin packaging or marketplace
registration. The source is the repository that ships this script; the install
target is the current working directory. Re-running is idempotent.
"""

from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path

SKILL_NAME = "gherkin-bdd"
BOOTSTRAP_SKILL_NAME = "bdd-bootstrap"
CODE_TO_GHERKIN_SKILL_NAME = "code-to-gherkin"
COMPANION_SKILL_NAMES = (BOOTSTRAP_SKILL_NAME, CODE_TO_GHERKIN_SKILL_NAME)
SESSION_HOOK_MATCHER = "startup|resume"
SESSION_HOOK_MARKER = "check_bdd_sync.py"
SESSION_HOOK_STATUS = "Syncing BDD rule"

SOURCE = Path(__file__).resolve().parent.parent
CODING_AGENT_SKILL_DIRS = {"claude": ".claude/skills", "codex": ".agents/skills"}
CODING_AGENT_HOOK_FILES = {"claude": ".claude/settings.json", "codex": ".codex/hooks.json"}


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    install(Path.cwd(), args.coding_agent)
    return 0


def parse_args(argv: list[str] | None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="bdd-bootstrap",
        description=(
            "Install the Gherkin BDD skill into the current directory "
            "for Claude Code or Codex."
        ),
    )
    parser.add_argument(
        "coding_agent",
        choices=("claude", "codex"),
        help="Which coding agent to install for.",
    )
    return parser.parse_args(argv)


def install(project_dir: Path, coding_agent: str) -> None:
    validate_source()
    skills_root = project_dir / CODING_AGENT_SKILL_DIRS[coding_agent]
    skill_dir = skills_root / SKILL_NAME
    print(f"Skill target: {skill_dir}")
    install_skill(skill_dir)
    for name in COMPANION_SKILL_NAMES:
        companion_dir = skills_root / name
        print(f"Skill target: {companion_dir}")
        install_companion_skill(companion_dir, name)

    skill_ref = f"{CODING_AGENT_SKILL_DIRS[coding_agent]}/{SKILL_NAME}"
    bdd_ref = f"{skill_ref}/BDD.md"
    if coding_agent == "claude":
        command = (
            f'python3 "${{CLAUDE_PROJECT_DIR}}/{skill_ref}/scripts/check_bdd_sync.py" '
            f'--coding-agent claude --bdd-ref "{bdd_ref}"'
        )
        status_message = None
    else:
        script = skill_dir / "scripts" / "check_bdd_sync.py"
        command = f'python3 "{script}" --coding-agent codex --bdd-ref "{bdd_ref}"'
        status_message = SESSION_HOOK_STATUS
    register_hook(project_dir / CODING_AGENT_HOOK_FILES[coding_agent], command, status_message)
    run_bdd_sync(project_dir, skill_dir / "scripts" / "check_bdd_sync.py", coding_agent, bdd_ref)


def validate_source() -> None:
    required = (
        SOURCE / "skills" / SKILL_NAME / "SKILL.md",
        *(SOURCE / "skills" / name / "SKILL.md" for name in COMPANION_SKILL_NAMES),
        SOURCE / "scripts" / "check_bdd_sync.py",
        SOURCE / "scripts" / "gherkin_to_html.py",
        SOURCE / "BDD.md",
    )
    missing = [str(path) for path in required if not path.exists()]
    if missing:
        raise SystemExit("Source is missing required paths:\n" + "\n".join(missing))


def install_skill(skill_dir: Path) -> None:
    reset_dir(skill_dir)
    copy_path(SOURCE / "skills" / SKILL_NAME / "SKILL.md", skill_dir / "SKILL.md")
    copy_path(SOURCE / "BDD.md", skill_dir / "BDD.md")
    copy_path(
        SOURCE / "scripts" / "check_bdd_sync.py",
        skill_dir / "scripts" / "check_bdd_sync.py",
    )
    copy_path(
        SOURCE / "scripts" / "gherkin_to_html.py",
        skill_dir / "scripts" / "gherkin_to_html.py",
    )


def install_companion_skill(skill_dir: Path, name: str) -> None:
    reset_dir(skill_dir)
    copy_path(SOURCE / "skills" / name / "SKILL.md", skill_dir / "SKILL.md")


def reset_dir(path: Path) -> None:
    if path.exists() or path.is_symlink():
        remove_path(path)
    path.mkdir(parents=True, exist_ok=True)


def run_bdd_sync(project_dir: Path, script: Path, coding_agent: str, bdd_ref: str) -> None:
    """Sync the BDD rule using the very same script the SessionStart hook runs.

    The installer feeds the script the same JSON payload a SessionStart hook
    would, so install-time and session-time sync share one implementation.
    """
    print(f"  sync BDD rule ({script.name} --coding-agent {coding_agent})")
    payload = json.dumps(
        {"cwd": str(project_dir), "hook_event_name": "SessionStart", "source": "startup"}
    )
    result = subprocess.run(
        [sys.executable, str(script), "--coding-agent", coding_agent, "--bdd-ref", bdd_ref],
        input=payload,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(f"BDD sync failed ({script}).")
    message = read_system_message(result.stdout)
    if message:
        print(f"  {message}")


def read_system_message(stdout: str) -> str | None:
    stdout = stdout.strip()
    if not stdout:
        return None
    try:
        return json.loads(stdout).get("systemMessage")
    except json.JSONDecodeError:
        return None


def register_hook(config_path: Path, command: str, status_message: str | None) -> None:
    print(f"Session hook: {config_path}")
    payload = read_json_object(config_path)
    hooks = payload.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        raise SystemExit(f"{config_path} field 'hooks' must be an object.")
    session_start = hooks.setdefault("SessionStart", [])
    if not isinstance(session_start, list):
        raise SystemExit(f"{config_path} field 'hooks.SessionStart' must be an array.")

    entry = {
        "matcher": SESSION_HOOK_MATCHER,
        "hooks": [build_hook_command(command, status_message)],
    }
    index = find_hook_index(session_start)
    if index is not None:
        if session_start[index] == entry:
            print("  hook already current")
            return
        print("  update hook")
        session_start[index] = entry
    else:
        print("  add hook")
        session_start.append(entry)
    write_json(config_path, payload)


def build_hook_command(command: str, status_message: str | None) -> dict:
    hook: dict = {"type": "command", "command": command}
    if status_message:
        hook["statusMessage"] = status_message
    return hook


def find_hook_index(session_start: list) -> int | None:
    for index, entry in enumerate(session_start):
        if not isinstance(entry, dict):
            continue
        for hook in entry.get("hooks", []):
            if isinstance(hook, dict) and SESSION_HOOK_MARKER in str(hook.get("command", "")):
                return index
    return None


def read_json_object(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"{path} is not valid JSON: {error}") from error
    if not isinstance(payload, dict):
        raise SystemExit(f"{path} must contain a JSON object.")
    return payload


def copy_path(source: Path, target: Path) -> None:
    print(f"  copy {source.name}")
    target.parent.mkdir(parents=True, exist_ok=True)
    if source.is_dir():
        shutil.copytree(source, target)
    else:
        shutil.copy2(source, target)


def remove_path(path: Path) -> None:
    print(f"  replace {path}")
    if path.is_symlink() or path.is_file():
        path.unlink()
    else:
        shutil.rmtree(path)


def write_json(path: Path, payload: dict) -> None:
    print(f"  write {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        raise SystemExit(130)
