#!/usr/bin/env python3
"""Install this plugin into the current directory for Claude Code or Codex.

Usage:

    bdd-bootstrap claude    # install for Claude Code + register its hook
    bdd-bootstrap codex     # install for Codex + register its hook

The plugin source is the repository that ships this script; the install target
is the current working directory. Re-running is idempotent.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

PLUGIN_NAME = "gherkin-bdd"
DEFAULT_MARKETPLACE_NAME = "project"
DEFAULT_MARKETPLACE_DISPLAY_NAME = "Project"
DEFAULT_CATEGORY = "Productivity"
SHARED_ENTRIES = ("skills", "docs", "examples", "scripts", "hooks", "README.md", "BDD.md")
CHECK_SCRIPT_RELPATH = "scripts/check_bdd_sync.py"
SESSION_HOOK_MATCHER = "startup|resume"
SESSION_HOOK_MARKER = "check_bdd_sync.py"
SESSION_HOOK_STATUS = "Syncing BDD rule"

SOURCE = Path(__file__).resolve().parent.parent


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    project_dir = Path.cwd()
    if args.host == "claude":
        install_claude(project_dir)
    else:
        install_codex(project_dir)
    return 0


def parse_args(argv: list[str] | None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="bdd-bootstrap",
        description="Install this plugin into the current directory for Claude Code or Codex.",
    )
    parser.add_argument(
        "host",
        choices=("claude", "codex"),
        help="Which host to install for.",
    )
    return parser.parse_args(argv)


def install_claude(project_dir: Path) -> None:
    target = project_dir / ".claude" / "skills" / PLUGIN_NAME
    print(f"Claude Code target: {target}")
    install_tree(target=target, host_manifest=".claude-plugin")

    bdd_ref = os.path.relpath(target / "BDD.md", project_dir)
    script = f".claude/skills/{PLUGIN_NAME}/{CHECK_SCRIPT_RELPATH}"
    command = f'python3 "${{CLAUDE_PROJECT_DIR}}/{script}" --host claude --bdd-ref "{bdd_ref}"'
    register_hook(project_dir / ".claude" / "settings.json", command, status_message=None)
    run_bdd_sync(project_dir, target / CHECK_SCRIPT_RELPATH, "claude", bdd_ref)


def install_codex(project_dir: Path) -> None:
    plugin_dir = project_dir / ".agents" / "plugins" / "plugins" / PLUGIN_NAME
    print(f"Codex plugin target: {plugin_dir}")
    install_tree(target=plugin_dir, host_manifest=".codex-plugin")
    update_codex_marketplace(project_dir / ".agents" / "plugins" / "marketplace.json", plugin_dir)

    bdd_ref = os.path.relpath(plugin_dir / "BDD.md", project_dir)
    command = f'python3 "{plugin_dir / CHECK_SCRIPT_RELPATH}" --host codex --bdd-ref "{bdd_ref}"'
    register_hook(project_dir / ".codex" / "hooks.json", command, status_message=SESSION_HOOK_STATUS)
    run_bdd_sync(project_dir, plugin_dir / CHECK_SCRIPT_RELPATH, "codex", bdd_ref)


def run_bdd_sync(project_dir: Path, script: Path, host: str, bdd_ref: str) -> None:
    """Sync the BDD rule using the very same script the SessionStart hook runs.

    The installer feeds the script the same JSON payload a SessionStart hook
    would, so install-time and session-time sync share one implementation.
    """
    print(f"  sync BDD rule ({script.name} --host {host})")
    payload = json.dumps(
        {"cwd": str(project_dir), "hook_event_name": "SessionStart", "source": "startup"}
    )
    result = subprocess.run(
        [sys.executable, str(script), "--host", host, "--bdd-ref", bdd_ref],
        input=payload,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(f"BDD sync failed ({script}).")
    message = read_system_message(result.stdout)
    if message:
        print(f"  {message}")


def read_system_message(stdout: str) -> str | None:
    stdout = stdout.strip()
    if not stdout:
        return None
    try:
        return json.loads(stdout).get("systemMessage")
    except json.JSONDecodeError:
        return None


def install_tree(*, target: Path, host_manifest: str) -> None:
    if target.exists() or target.is_symlink():
        remove_path(target)
    target.mkdir(parents=True, exist_ok=True)
    copy_path(SOURCE / host_manifest, target / host_manifest)
    for entry_name in SHARED_ENTRIES:
        entry = SOURCE / entry_name
        if entry.exists():
            copy_path(entry, target / entry_name)


def update_codex_marketplace(marketplace: Path, plugin_dir: Path) -> None:
    print(f"Codex marketplace: {marketplace}")
    entry_path = relative_source_path(marketplace.parent, plugin_dir)
    payload = read_marketplace(marketplace)
    plugins = payload.setdefault("plugins", [])
    if not isinstance(plugins, list):
        raise SystemExit(f"{marketplace} field 'plugins' must be an array.")

    new_entry = {
        "name": PLUGIN_NAME,
        "source": {"source": "local", "path": entry_path},
        "policy": {"installation": "AVAILABLE", "authentication": "ON_INSTALL"},
        "category": DEFAULT_CATEGORY,
    }
    for index, existing in enumerate(plugins):
        if isinstance(existing, dict) and existing.get("name") == PLUGIN_NAME:
            plugins[index] = new_entry
            break
    else:
        plugins.append(new_entry)
    write_json(marketplace, payload)


def register_hook(config_path: Path, command: str, status_message: str | None) -> None:
    print(f"Session hook: {config_path}")
    payload = read_json_object(config_path)
    hooks = payload.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        raise SystemExit(f"{config_path} field 'hooks' must be an object.")
    session_start = hooks.setdefault("SessionStart", [])
    if not isinstance(session_start, list):
        raise SystemExit(f"{config_path} field 'hooks.SessionStart' must be an array.")

    entry = {
        "matcher": SESSION_HOOK_MATCHER,
        "hooks": [build_hook_command(command, status_message)],
    }
    index = find_hook_index(session_start)
    if index is not None:
        if session_start[index] == entry:
            print("  hook already current")
            return
        print("  update hook")
        session_start[index] = entry
    else:
        print("  add hook")
        session_start.append(entry)
    write_json(config_path, payload)


def build_hook_command(command: str, status_message: str | None) -> dict:
    hook: dict = {"type": "command", "command": command}
    if status_message:
        hook["statusMessage"] = status_message
    return hook


def find_hook_index(session_start: list) -> int | None:
    for index, entry in enumerate(session_start):
        if not isinstance(entry, dict):
            continue
        for hook in entry.get("hooks", []):
            if isinstance(hook, dict) and SESSION_HOOK_MARKER in str(hook.get("command", "")):
                return index
    return None


def read_json_object(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"{path} is not valid JSON: {error}") from error
    if not isinstance(payload, dict):
        raise SystemExit(f"{path} must contain a JSON object.")
    return payload


def read_marketplace(path: Path) -> dict:
    payload = read_json_object(path)
    payload.setdefault("name", DEFAULT_MARKETPLACE_NAME)
    payload.setdefault("interface", {"displayName": DEFAULT_MARKETPLACE_DISPLAY_NAME})
    return payload


def relative_source_path(base: Path, target: Path) -> str:
    try:
        relative = os.path.relpath(target, base)
    except ValueError:
        return target.as_posix()
    if relative.startswith(".."):
        return target.as_posix()
    return f"./{Path(relative).as_posix()}"


def copy_path(source: Path, target: Path) -> None:
    print(f"  copy {source.name}")
    target.parent.mkdir(parents=True, exist_ok=True)
    if source.is_dir():
        shutil.copytree(source, target)
    else:
        shutil.copy2(source, target)


def remove_path(path: Path) -> None:
    print(f"  replace {path}")
    if path.is_symlink() or path.is_file():
        path.unlink()
    else:
        shutil.rmtree(path)


def write_json(path: Path, payload: dict) -> None:
    print(f"  write {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        raise SystemExit(130)
