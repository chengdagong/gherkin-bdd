#!/usr/bin/env python3
"""Install this plugin for Codex and Claude Code."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable


PLUGIN_NAME = "gherkin-bdd"
DEFAULT_MARKETPLACE_NAME = "project"
DEFAULT_MARKETPLACE_DISPLAY_NAME = "Project"
DEFAULT_CATEGORY = "Productivity"
SHARED_ENTRIES = ("skills", "docs", "examples", "scripts", "hooks", "README.md", "BDD.md")
PROJECT_INSTRUCTION_FILES = ("CLAUDE.md", "AGENTS.md")
CHECK_SCRIPT_RELPATH = "scripts/check_bdd_sync.py"
SESSION_HOOK_MATCHER = "startup|resume"
SESSION_HOOK_MARKER = "check_bdd_sync.py"
SESSION_HOOK_STATUS = "Syncing BDD rule"


@dataclass(frozen=True)
class InstallPlan:
    source: Path
    project_dir: Path
    plugin_name: str
    targets: tuple[str, ...]
    create_missing_instructions: str
    force: bool
    dry_run: bool
    claude_dir: Path
    codex_marketplace: Path
    codex_plugin_dir: Path | None
    claude_settings: Path
    codex_hooks: Path


def main(argv: list[str] | None = None, input_func=input) -> int:
    args = parse_args(argv)
    if args.command == "run":
        plan = build_install_plan(args)
        install(plan, input_func)
        return 0
    if args.command == "show-paths":
        plan = build_install_plan(args)
        print_paths(plan)
        return 0
    raise AssertionError(f"Unhandled command: {args.command}")


def parse_args(argv: list[str] | None) -> argparse.Namespace:
    raw_args = sys.argv[1:] if argv is None else argv
    if raw_args and raw_args[0] == "show-paths":
        return parse_subcommand_args(raw_args)
    return parse_install_args(raw_args)


def parse_install_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="bdd-bootstrap",
        description="Install this plugin into a project for Claude Code and Codex.",
    )
    add_common_options(parser)
    parser.add_argument(
        "--force",
        action="store_true",
        help="Replace an existing generated install directory or marketplace entry.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the install actions without writing files.",
    )
    parser.add_argument(
        "--create-missing-instructions",
        choices=("ask", "yes", "no"),
        default="ask",
        help=(
            "Create missing CLAUDE.md or AGENTS.md with BDD.md content. "
            "Defaults to ask."
        ),
    )
    parser.set_defaults(command="run")
    return parser.parse_args(argv)


def parse_subcommand_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="bdd-bootstrap",
        description="Install this plugin into a project for Claude Code and Codex.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)
    paths_parser = subparsers.add_parser("show-paths", help="Show resolved install paths")
    add_common_options(paths_parser)

    return parser.parse_args(argv)


def add_common_options(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--source",
        default=".",
        help="Plugin source directory. Defaults to the current directory.",
    )
    parser.add_argument(
        "--project-dir",
        default=".",
        help="Project directory to install into. Defaults to the current directory.",
    )
    parser.add_argument(
        "--plugin-name",
        default=PLUGIN_NAME,
        help=f"Plugin name and namespace. Defaults to {PLUGIN_NAME}.",
    )
    parser.add_argument(
        "--target",
        choices=("both", "claude", "codex"),
        default="both",
        help="Which host to install for. Defaults to both.",
    )


def build_install_plan(args: argparse.Namespace) -> InstallPlan:
    source = Path(args.source).expanduser().resolve()
    project_dir = Path(args.project_dir).expanduser().resolve()
    plugin_name = normalize_plugin_name(args.plugin_name)
    if not plugin_name:
        raise SystemExit("Plugin name must include at least one ASCII letter or digit.")

    targets = ("claude", "codex") if args.target == "both" else (args.target,)
    claude_dir = project_dir / ".claude" / "skills"
    codex_marketplace = project_dir / ".agents" / "plugins" / "marketplace.json"
    codex_plugin_dir = codex_marketplace.parent / "plugins" / plugin_name
    claude_settings = project_dir / ".claude" / "settings.json"
    codex_hooks = project_dir / ".codex" / "hooks.json"

    return InstallPlan(
        source=source,
        project_dir=project_dir,
        plugin_name=plugin_name,
        targets=targets,
        create_missing_instructions=getattr(args, "create_missing_instructions", "ask"),
        force=getattr(args, "force", False),
        dry_run=getattr(args, "dry_run", False),
        claude_dir=claude_dir,
        codex_marketplace=codex_marketplace,
        codex_plugin_dir=codex_plugin_dir,
        claude_settings=claude_settings,
        codex_hooks=codex_hooks,
    )


def normalize_plugin_name(raw_name: str) -> str:
    chars: list[str] = []
    previous_was_dash = False
    for char in raw_name.strip().lower():
        if char.isascii() and char.isalnum():
            chars.append(char)
            previous_was_dash = False
        elif not previous_was_dash:
            chars.append("-")
            previous_was_dash = True
    return "".join(chars).strip("-")


def install(plan: InstallPlan, input_func=input) -> None:
    validate_source(plan.source)
    if "claude" in plan.targets:
        install_claude(plan)
    if "codex" in plan.targets:
        install_codex(plan)
    append_bdd_requirements(plan, input_func)


def validate_source(source: Path) -> None:
    required_paths = (
        source / ".claude-plugin" / "plugin.json",
        source / ".codex-plugin" / "plugin.json",
        source / "BDD.md",
        source / "skills",
    )
    missing = [str(path) for path in required_paths if not path.exists()]
    if missing:
        raise SystemExit("Plugin source is missing required paths:\n" + "\n".join(missing))


def install_claude(plan: InstallPlan) -> None:
    target = plan.claude_dir / plan.plugin_name
    print(f"Claude Code target: {target}")
    print("  mode: copy")
    install_tree(
        source=plan.source,
        target=target,
        host_manifest=".claude-plugin",
        shared_entries=SHARED_ENTRIES,
        install_mode="copy",
        force=plan.force,
        dry_run=plan.dry_run,
    )
    register_claude_hook(plan)


def install_codex(plan: InstallPlan) -> None:
    if plan.codex_plugin_dir is None:
        raise AssertionError("codex_plugin_dir should be resolved")

    print(f"Codex plugin target: {plan.codex_plugin_dir}")
    print("  mode: symlink")
    install_tree(
        source=plan.source,
        target=plan.codex_plugin_dir,
        host_manifest=".codex-plugin",
        shared_entries=SHARED_ENTRIES,
        install_mode="symlink",
        force=plan.force,
        dry_run=plan.dry_run,
    )
    update_codex_marketplace(plan)
    register_codex_hook(plan)


def install_tree(
    *,
    source: Path,
    target: Path,
    host_manifest: str,
    shared_entries: Iterable[str],
    install_mode: str,
    force: bool,
    dry_run: bool,
) -> None:
    if target.exists() or target.is_symlink():
        if not force:
            raise SystemExit(f"{target} already exists. Re-run with --force to replace it.")
        remove_path(target, dry_run)

    mkdir(target, dry_run)
    link_or_copy(source / host_manifest, target / host_manifest, install_mode, dry_run)
    for entry_name in shared_entries:
        entry = source / entry_name
        if entry.exists():
            link_or_copy(entry, target / entry_name, install_mode, dry_run)


def update_codex_marketplace(plan: InstallPlan) -> None:
    marketplace = plan.codex_marketplace
    print(f"Codex project marketplace: {marketplace}")
    entry_path = relative_source_path(marketplace.parent, plan.codex_plugin_dir)

    payload = read_marketplace(marketplace)
    plugins = payload.setdefault("plugins", [])
    if not isinstance(plugins, list):
        raise SystemExit(f"{marketplace} field 'plugins' must be an array.")

    new_entry = {
        "name": plan.plugin_name,
        "source": {
            "source": "local",
            "path": entry_path,
        },
        "policy": {
            "installation": "AVAILABLE",
            "authentication": "ON_INSTALL",
        },
        "category": DEFAULT_CATEGORY,
    }

    for index, existing in enumerate(plugins):
        if isinstance(existing, dict) and existing.get("name") == plan.plugin_name:
            if not plan.force and existing != new_entry:
                raise SystemExit(
                    f"{marketplace} already contains '{plan.plugin_name}'. "
                    "Re-run with --force to replace that entry."
                )
            plugins[index] = new_entry
            break
    else:
        plugins.append(new_entry)

    write_json(marketplace, payload, plan.dry_run)


def register_claude_hook(plan: InstallPlan) -> None:
    script = f".claude/skills/{plan.plugin_name}/{CHECK_SCRIPT_RELPATH}"
    command = f'python3 "${{CLAUDE_PROJECT_DIR}}/{script}"'
    print(f"Claude Code session hook: {plan.claude_settings}")
    upsert_session_start_hook(
        config_path=plan.claude_settings,
        command=command,
        status_message=None,
        force=plan.force,
        dry_run=plan.dry_run,
    )


def register_codex_hook(plan: InstallPlan) -> None:
    if plan.codex_plugin_dir is None:
        raise AssertionError("codex_plugin_dir should be resolved")
    script = plan.codex_plugin_dir / CHECK_SCRIPT_RELPATH
    command = f'python3 "{script}"'
    print(f"Codex session hook: {plan.codex_hooks}")
    upsert_session_start_hook(
        config_path=plan.codex_hooks,
        command=command,
        status_message=SESSION_HOOK_STATUS,
        force=plan.force,
        dry_run=plan.dry_run,
    )


def upsert_session_start_hook(
    *,
    config_path: Path,
    command: str,
    status_message: str | None,
    force: bool,
    dry_run: bool,
) -> None:
    payload = read_hook_config(config_path)
    hooks = payload.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        raise SystemExit(f"{config_path} field 'hooks' must be an object.")
    session_start = hooks.setdefault("SessionStart", [])
    if not isinstance(session_start, list):
        raise SystemExit(f"{config_path} field 'hooks.SessionStart' must be an array.")

    entry = {
        "matcher": SESSION_HOOK_MATCHER,
        "hooks": [build_hook_command(command, status_message)],
    }
    existing_index = find_session_hook_index(session_start)
    if existing_index is not None:
        if not force and session_start[existing_index] == entry:
            print(f"  already registered in {config_path}")
            return
        if not force:
            print(f"  update SessionStart check in {config_path}")
        session_start[existing_index] = entry
    else:
        print(f"  add SessionStart check to {config_path}")
        session_start.append(entry)

    write_json(config_path, payload, dry_run)


def build_hook_command(command: str, status_message: str | None) -> dict:
    hook: dict = {"type": "command", "command": command}
    if status_message:
        hook["statusMessage"] = status_message
    return hook


def find_session_hook_index(session_start: list) -> int | None:
    for index, entry in enumerate(session_start):
        if not isinstance(entry, dict):
            continue
        for hook in entry.get("hooks", []):
            if isinstance(hook, dict) and SESSION_HOOK_MARKER in str(hook.get("command", "")):
                return index
    return None


def read_hook_config(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"{path} is not valid JSON: {error}") from error
    if not isinstance(payload, dict):
        raise SystemExit(f"{path} must contain a JSON object.")
    return payload


def append_bdd_requirements(plan: InstallPlan, input_func=input) -> None:
    bdd_path = plan.source / "BDD.md"
    bdd_content = bdd_path.read_text(encoding="utf-8").strip()
    if not bdd_content:
        raise SystemExit(f"{bdd_path} must not be empty.")

    instruction_files = find_project_instruction_files(plan.project_dir)
    for path in instruction_files:
        append_bdd_to_instruction_file(path, bdd_content, plan.dry_run)
    create_missing_instruction_files(plan, instruction_files, bdd_content, input_func)


def find_project_instruction_files(project_dir: Path) -> list[Path]:
    if not project_dir.exists():
        return []
    expected_names = {name.lower() for name in PROJECT_INSTRUCTION_FILES}
    return sorted(
        path
        for path in project_dir.iterdir()
        if path.is_file() and path.name.lower() in expected_names
    )


def create_missing_instruction_files(
    plan: InstallPlan,
    existing_files: list[Path],
    bdd_content: str,
    input_func=input,
) -> None:
    existing_names = {path.name.lower() for path in existing_files}
    missing_files = [
        plan.project_dir / name
        for name in PROJECT_INSTRUCTION_FILES
        if name.lower() not in existing_names
    ]
    if not missing_files:
        return

    for path in missing_files:
        if should_create_instruction_file(path, plan, input_func):
            create_instruction_file(path, bdd_content, plan.dry_run)
        else:
            print(f"Project instructions: skipped missing {path}")


def should_create_instruction_file(path: Path, plan: InstallPlan, input_func=input) -> bool:
    if plan.dry_run:
        print(f"Project instructions: missing {path}")
        return False
    if plan.create_missing_instructions == "yes":
        return True
    if plan.create_missing_instructions == "no":
        return False

    try:
        answer = input_func(f"Create {path} with BDD.md content? [y/N] ")
    except EOFError:
        return False
    return answer.strip().lower() in {"y", "yes"}


def create_instruction_file(path: Path, bdd_content: str, dry_run: bool) -> None:
    print(f"Project instructions: create {path}")
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(bdd_content + "\n", encoding="utf-8")


def append_bdd_to_instruction_file(path: Path, bdd_content: str, dry_run: bool) -> None:
    existing = path.read_text(encoding="utf-8")
    if bdd_content in existing:
        print(f"Project instructions: {path} already contains BDD.md")
        return

    print(f"Project instructions: append BDD.md to {path}")
    if dry_run:
        return

    separator = "\n\n" if existing.strip() else ""
    path.write_text(existing.rstrip() + separator + bdd_content + "\n", encoding="utf-8")


def read_marketplace(path: Path) -> dict:
    if not path.exists():
        return {
            "name": DEFAULT_MARKETPLACE_NAME,
            "interface": {
                "displayName": DEFAULT_MARKETPLACE_DISPLAY_NAME,
            },
            "plugins": [],
        }
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"{path} is not valid JSON: {error}") from error
    if not isinstance(payload, dict):
        raise SystemExit(f"{path} must contain a JSON object.")
    payload.setdefault("name", DEFAULT_MARKETPLACE_NAME)
    payload.setdefault("interface", {"displayName": DEFAULT_MARKETPLACE_DISPLAY_NAME})
    return payload


def relative_source_path(base: Path, target: Path | None) -> str:
    if target is None:
        raise AssertionError("target should be resolved")
    try:
        relative = os.path.relpath(target, base)
    except ValueError:
        return target.as_posix()
    if relative.startswith(".."):
        return target.as_posix()
    return f"./{Path(relative).as_posix()}"


def link_or_copy(source: Path, target: Path, link_mode: str, dry_run: bool) -> None:
    if link_mode == "copy":
        copy_path(source, target, dry_run)
        return
    symlink(source, target, dry_run)


def symlink(source: Path, target: Path, dry_run: bool) -> None:
    print(f"  symlink {target} -> {source}")
    if dry_run:
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    target.symlink_to(source, target_is_directory=source.is_dir())


def copy_path(source: Path, target: Path, dry_run: bool) -> None:
    print(f"  copy {source} -> {target}")
    if dry_run:
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    if source.is_dir():
        shutil.copytree(source, target)
    else:
        shutil.copy2(source, target)


def mkdir(path: Path, dry_run: bool) -> None:
    print(f"  mkdir {path}")
    if not dry_run:
        path.mkdir(parents=True, exist_ok=True)


def remove_path(path: Path, dry_run: bool) -> None:
    print(f"  replace {path}")
    if dry_run:
        return
    if path.is_symlink() or path.is_file():
        path.unlink()
    else:
        shutil.rmtree(path)


def write_json(path: Path, payload: dict, dry_run: bool) -> None:
    print(f"  write {path}")
    if dry_run:
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def print_paths(plan: InstallPlan) -> None:
    print(f"Source: {plan.source}")
    print(f"Project: {plan.project_dir}")
    if "claude" in plan.targets:
        print(f"Claude Code: {plan.claude_dir / plan.plugin_name}")
        print(f"Claude Code session hook: {plan.claude_settings}")
    if "codex" in plan.targets:
        print(f"Codex plugin: {plan.codex_plugin_dir}")
        print(f"Codex project marketplace: {plan.codex_marketplace}")
        print(f"Codex session hook: {plan.codex_hooks}")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        raise SystemExit(130)
